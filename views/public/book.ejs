<!DOCTYPE html>
<html lang="en">

<%- include('partials/head') %>
<%- include('partials/nav') %>

 <section id="book-section" class="home-section">
     <div class="container">
         <div class="d-flex justify-content-center">
             <div class=" col-md-7 bg-dark shadow-lg rounded py-5 ">             
               <form class="p-5">
                    <div class="form-floating mb-3">
                      <input type="email" class="form-control" id="floatingInput" placeholder="name@example.com">
                      <label for="floatingInput">Email address</label>
                    </div>
                    <div class="form-floating">
                      <input type="password" class="form-control" id="floatingPassword" placeholder="Password">
                      <label for="floatingPassword">Password</label>
                    </div>
               </form>
             </div>             
         </div>
     </div>
 </section>
 <footer class="footer-custom bg-dark text-white pt-5 pb-3">
    <div class="container">
        <div class="row g-4">
            <div class="col-lg-4 col-md-6">
                <div class="d-flex align-items-center mb-3">
                    <img src="logo/logo.png" alt="Sandigan Logo" style="height: 40px;" class="me-2" />
                    <strong class="fs-4 brand-name" style="color: #00e8e9; letter-spacing: 2px;">SANDIGAN</strong>
                </div>
                <p class="text-secondary small">
                    Providing premium carwash and detailing services with a focus on quality and customer satisfaction. Your vehicle deserves the best care.
                </p>
                <div class="social-links mt-4">
                    <a href="#" class="me-3 text-white fs-5"><i class="bi bi-facebook"></i></a>
                    <a href="#" class="me-3 text-white fs-5"><i class="bi bi-instagram"></i></a>
                    <a href="#" class="text-white fs-5"><i class="bi bi-messenger"></i></a>
                </div>
            </div>

            <div class="col-lg-2 col-md-6">
                <h5 class="fw-bold mb-4 border-bottom border-primary pb-2 d-inline-block">Quick Links</h5>
                <ul class="list-unstyled footer-links">
                    <li class="mb-2"><a href="#home-section" class="text-secondary text-decoration-none">Home</a></li>
                    <li class="mb-2"><a href="#services-section" class="text-secondary text-decoration-none">Services</a></li>
                    <li class="mb-2"><a href="#service-price-section" class="text-secondary text-decoration-none">Price List</a></li>
                    <li class="mb-2"><a href="#about-section" class="text-secondary text-decoration-none">About Us</a></li>
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <h5 class="fw-bold mb-4 border-bottom border-primary pb-2 d-inline-block">Operating Hours</h5>
                <ul class="list-unstyled text-secondary small">
                    <li class="d-flex justify-content-between mb-2">
                        <span>Monday - Saturday:</span>
                        <span class="text-white">8:00 AM - 6:00 PM</span>
                    </li>
                    <li class="d-flex justify-content-between mb-2">
                        <span>Sunday:</span>
                        <span class="text-white">8:00 AM - 5:00 PM</span>
                    </li>
                    <li class="mt-3 text-info small">
                        <i class="bi bi-info-circle me-1">Holiday hours may vary</i>
                    </li>
                </ul>
            </div>

            <div class="col-lg-3 col-md-6">
                <h5 class="fw-bold mb-4 border-bottom border-primary pb-2 d-inline-block">Contact Us</h5>
                <ul class="list-unstyled text-secondary small">
                    <li class="mb-3 d-flex align-items-start">
                        <i class="bi bi-geo-alt-fill text-primary"></i>
                        <span>123 Sandigan St., Brgy. Sample, Taguig City, Philippines</span>
                    </li>
                    <li class="mb-3 d-flex align-items-center">
                        <i class="bi bi-telephone-fill text-primary"></i>
                        <span>+63 912 345 6789</span>
                    </li>
                    <li class="d-flex align-items-center">
                        <i class="bi bi-envelope-fill text-primary"></i>
                        <span>contact@sandigancarwash.com</span>
                    </li>
                </ul>
            </div>
        </div>

		<hr class="mt-5 mb-4 border-secondary opacity-25"></hr>

        <div class="row align-items-center">
            <div class="col-md-6 text-center text-md-start">
                <p class="small text-secondary mb-0">© 2026 Sandigan Carwash. All Rights Reserved.</p>
            </div>
            <div class="col-md-6 text-center text-md-end mt-3 mt-md-0">
                <p class="small text-secondary mb-0">BSIS-3B</p>
            </div>
        </div>
    </div>
</footer>
