<!DOCTYPE html>
<html lang="en"> </html>
	
<%- include('partials/head') %>
<%- include('partials/nav') %>

<NavBar />	
<main class="landing-wrapper">
    <section id="home-section" class="home-section py-5">
        <div class="container py-5">
            <div class="row align-items-center py-5">
                <div class="col-md-6">
                    <h1 class="display-3 fw-bold hero-title">
                        Sandigan Carwash <br />
                        <span class="brand-accent">Quality Service.</span>
                    </h1>
                    <p class="lead hero-description mt-3">
                        Experience the best carwash in town with Sandigan Carwash.
                    </p>
                    <div class="mt-4">
                        <a href="/book" class="btn btn-primary btn-lg shadow-lg d-flex align-items-center justify-content-center text-dark"
                           style="width: 13rem; height: 3.5rem; border-radius: 12px; background-color: #00e8e9; border: none;">
                            Book Now
                        </a>
                    </div>
                </div>
                <div class="col-md-6 text-center mt-5 mt-md-0">
                    <div class="hero-image-container shadow-lg">
                        <img src="img/carwash-img1.jpg" class="img-fluid" alt="Carwash Service" />
                    </div>
                </div>
            </div>
        </div>
    </section>
    <section id="services-section" class="service-section py-5">
        <div class="container py-5">
            <div class="text-center mb-5">
                <h6 class="text-primary fw-bold text-uppercase tracking-wider">Our Expertise</h6>
                <h2 class="display-5 fw-bold text-dark">Premium Carwash Services</h2>
                <div class="mx-auto bg-dark mt-3" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
            <div class="row g-4 py-5">
                <div class="col-md-4">
                    <div class="service-card shadow-sm p-4 bg-white text-center h-100 border-bottom  border-4">                     
                        <div class="service-image-wrapper">
                            <img src="/img/carwash-img4.jpg" class="img-fluid" alt="Armor Wash Service" />
                        </div>
                        <h4 class="fw-bold text-dark">Armor Wash</h4>
                        <p class="text-muted small">Our signature deep-cleaning process that creates a protective barrier for your vehicle's exterior.</p>
						<hr class="my-4 opacity-25"></hr>
                        <ul class="list-unstyled text-start small text-center">
                            <li class="mb-2"><i class="bi bi-check2-circle text-success me-2"></i>Protective foam finish</li>
                            <li><i class="bi bi-check2-circle text-success me-2"></i>Superior paint shield</li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="service-card shadow-sm p-4 bg-white text-center h-100 border-bottom border-4">
                        <div class="service-image-wrapper">
                            <img src="/img/carwash-img2.jpg" class="img-fluid" alt="Armor Wash Service" />
                        </div>
                        <h4 class="fw-bold text-dark">Wax Wash</h4>
                        <p class="text-muted small">Deep cleaning of seats, carpets, and dashboard. We remove odors for a fresh experience.</p>
                        <hr class="my-4 opacity-25"></hr>
                        <ul class="list-unstyled text-start small text-center">
                            <li class="mb-2"><i class="bi bi-check2-circle text-info me-2"></i>Vacuum Sanitize</li>
                            <li><i class="bi bi-check2-circle text-info me-2"></i>Acid Rain Removal</li>
                        </ul>
                    </div>
                </div>

                <div class="col-md-4">
                    <div class="service-card shadow-sm p-4 bg-white text-center h-100 border-bottom  border-4">
                        <div class="service-image-wrapper">
                            <img src="/img/carwash-img5.jpg" class="img-fluid" alt="Armor Wash Service" />
                        </div>
                        <h4 class="fw-bold text-dark">Engine Wash</h4>
                        <p class="text-light-muted small">Ultimate protection with our specialized engine washing and wax armor treatments.</p>
                        <hr class="my-4 opacity-25"></hr>
                        <ul class="list-unstyled text-start small text-center">
                            <li class="mb-2"><i class="bi bi-check2-circle text-primary me-2"></i>Deep grease removal</li>
                            <li><i class="bi bi-check2-circle text-primary me-2"></i>Safe detail cleaning</li>
                        </ul>
                    </div>
                </div>
            </div>    
        </div>     
    </section>
    <section id="service-price-section" class="service-price-section py-5">
        <div class="container py-5">
            <div class="text-center mb-5">
                <h6 class="text-primary fw-bold text-uppercase tracking-wider">Our Rates</h6>
                <h2 class="display-5 fw-bold text-dark">Vehicle Service Menu</h2>
                <div class="mx-auto bg-dark mt-3" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
            <div class="border-bottom border-4" style="border-color: #1a1a1a !important; transition: transform 0.3s ease, box-shadow 0.3s ease; border-radius: 20px; ">
                <div class="table-responsive shadow-lg rounded-4 overflow-hidden">
                    <table class="table table-hover align-middle mb-0">
                        <thead class="bg-dark text-white">
                            <tr>
                                <th class="py-3 ps-4">Vehicle Type</th>
                                <th class="py-3 text-center">Body Wash</th>
                                <th class="py-3 text-center">Wax Wash</th>
                                <th class="py-3 text-center">Engine Wash</th>
                            </tr>
                        </thead>
                        <tbody>
							<% PriceList.forEach(function(item) { %>
							<tr>
								<td class="fw-bold ps-4 text-dark" data-label="Vehicle">
									<%= item.VehicleType %>
								</td>
								<td class="text-center text-muted" data-label="Body Wash">
									₱<%= item.Wash %>
								</td>
								<td class="text-center text-muted" data-label="Wax Wash">
									₱<%= item.Wax %>
								</td>
								<td class="text-center text-muted" data-label="Engine Wash">
									₱<%= item.Engine %>
								</td>
							</tr>
							<% }); %>
                        </tbody>
                    </table>
                </div>               
            </div>
            <p class="text-muted small mt-3">
                <i class="bi bi-info-circle me-1"></i>
                Prices may vary based on vehicle condition. Armor protection is +₱100 to any wash.
            </p>
        </div>
    </section>
    <section id="about-section" class="about-section  py-5">
        <div class="container py-5">
            <div class="text-center mb-5">
                <h6 class="text-primary fw-bold text-uppercase tracking-wider">About Us</h6>
                <h2 class="display-5 fw-bold text-dark">Why Choose Sandigan Carwash?</h2>
				<div class="mx-auto bg-dark mt-3" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
            <div class="row align-items-center my-5">
                <div class="col-md-6">
                    <h6 class="text-primary fw-bold text-uppercase">Sandigan Story</h6>
                    <h2 class="display-5 fw-semibold text-dark mb-4">Quality Service, <span class="">Trusted Care.</span></h2>
                    <p class="text-muted">
                        [Insert Answer: Sandigan Carwash started with a simple goal...]
                    </p>
                    <p class="text-muted">
                        We don't just wash cars; we protect your investment using the latest [Insert Answer: Detailing Tech] and a team that cares about every detail.
                    </p>
                </div>
                <div class="col-md-6">
                    <img src="img/carwash-img5.jpg" class="img-fluid shadow-lg" style="border-radius: 30px;" alt="About Sandigan Carwash" />
                </div>
            </div>
            <div class="row align-items-center">
                <div class="row-md-6 mb-5">
                    <img src="img/carwash-img5.jpg" class="img-fluid shadow-lg" style="border-radius: 30px;" alt="About Sandigan Carwash" />
                </div>
                <div class="row-md-6 text-center">
                    <h6 class="text-primary fw-bold text-uppercase">Sandigan Story</h6>
                    <h2 class="display-5 fw-semibold text-dark mb-4">Quality Service, <span class="">Trusted Care.</span></h2>
                    <p class="text-muted">
                        [Insert Answer: Sandigan Carwash started with a simple goal...]
                    </p>
                    <p class="text-muted">
                        We don't just wash cars; we protect your investment using the latest [Insert Answer: Detailing Tech] and a team that cares about every detail.
                    </p>
                </div>               
            </div>
        </div>
        <div class="container py-5">
            <div class="text-center mb-5">
                <h6 class="text-primary fw-bold text-uppercase tracking-wider">Testimonials</h6>
                <h2 class="display-5 fw-bold text-dark">What Our Customers Say</h2>
                <div class="mx-auto bg-dark mt-3" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>

            <div id="testimonialCarousel" class="carousel slide" data-bs-ride="carousel">
                <div class="carousel-inner">
                    <div class="carousel-item active">
                        <div class="row justify-content-center">
                            <div class="col-md-8 text-center">
                                <div class="testimonial-card shadow-lg p-5 bg-white rounded-4 border-bottom border-4 border-dark">
                                    <div class="mb-4">
                                        <i class="bi bi-person-circle display-1 text-muted"></i>
                                    </div>
                                    <p class="lead italic mb-4">"The best carwash in town! My SUV looks brand new every time I leave Sandigan. Highly recommended for their attention to detail."</p>
                                    <h5 class="fw-bold mb-0">Juan Dela Cruz</h5>
                                    <small class="text-primary">SUV Owner</small>
                                </div>
                            </div>
                        </div>
                    </div>

                    <div class="carousel-item">
                        <div class="row justify-content-center">
                            <div class="col-md-8 text-center">
                                <div class="testimonial-card shadow-lg p-5 bg-white rounded-4 border-bottom border-4 border-dark">
                                    <div class="mb-4">
                                        <i class="bi bi-person-circle display-1 text-muted"></i>
                                    </div>
                                    <p class="lead italic mb-4">"Super satisfied with the Engine Wash. Very professional staff and the waiting area is comfortable. Sulit ang bayad!"</p>
                                    <h5 class="fw-bold mb-0">Maria Santos</h5>
                                    <small class="text-primary">Sedan Owner</small>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <button class="carousel-control-prev" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon  p-3" aria-hidden="true"></span>
                    <span class="visually-hidden">Previous</span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#testimonialCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon  p-3" aria-hidden="true"></span>
                    <span class="visually-hidden">Next</span>
                </button>
            </div>
        </div>
    </section>
    <section id="contact-section" class="contact-section py-5">
        <div class="container py-5">
            <div class="text-center mb-5">
                <h6 class="text-White fw-bold text-uppercase tracking-wider" style=" color: #FAFAFA;">Get in Touch</h6>
                <h2 class="display-5 fw-bold text-White" style=" color: #00e8e9;">Contact Sandigan Carwash</h2>
                <div class="mx-auto bg-light mt-3" style="height: 4px; width: 60px; border-radius: 2px;"></div>
            </div>
            <div class="row justify-content-center">
                <div class="col-md-8">
                    <form>
                        <div class="mb-4">
                            <label for="name" class="form-label fw-bold">Name</label>
                            <input type="text" class="form-control" id="name" placeholder="e.g Bilat Puke" />
                        </div>
                        <div class="mb-4">
                            <label for="email" class="form-label fw-bold">Email</label>
                            <input type="email" class="form-control" id="email" placeholder="e.g Bilat@gmail.com" />
                        </div>
                        <div class="mb-4">
                            <label for="message" class="form-label fw-bold">Message</label>
                            <textarea class="form-control" id="message" rows="5" placeholder="e.g Baho bilat"></textarea>
                        </div>
                  
                        <div class="d-grid">
                            <button type="submit" class="btn btn-primary btn-lg shadow-lg d-flex align-items-center justify-content-center text-dark"
                                    style="width: 13rem; height: 3.5rem; border-radius: 12px; background-color: #00e8e9; border: none;">
                                Send Message
                            </button>
                        </div>
                    </form> 
                </div>
            </div>
        </div>
    </section>
</main> 
<%- include('partials/footer') %>